# Anthropic API Key (optionnel - peut être configuré dans l'interface)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Perplexity API Key
# PERPLEXITY_API_KEY=pplx-your-api-key-here

# Shopify API (OBLIGATOIRE pour OAuth)
SHOPIFY_API_KEY=your-shopify-api-key-here
SHOPIFY_API_SECRET=your-shopify-api-secret-here

# App URL (remplace par ton domaine Vercel en production)
NEXT_PUBLIC_APP_URL=https://ecomfarm-app.vercel.app
